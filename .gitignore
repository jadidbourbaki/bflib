*.dwo

# Benchmark artifacts. The compiled bench binaries are not portable
# across machines, and the generated CSVs / PDFs are expected to come
# from CI rather than from whichever laptop happened to run them.
# Anything checked-in by hand can be force-added with git add -f.
bench/*_bench
bench/*_results.csv
bench/*.pdf
bench/*.png

# Test binaries.
tests/*_test
